# Environment Variables (Optional)
# GULU works without any env vars — API key is entered in the UI.
# However, you can pre-configure these for development convenience.

# Google Gemini API Key (get one free at https://aistudio.google.com/apikey)
# WARNING: Never commit this file with a real key. It's in .gitignore.
VITE_GEMINI_API_KEY=your_api_key_here
